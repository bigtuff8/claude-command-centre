{
  "name": "claude-command-centre",
  "version": "0.1.0",
  "description": "Web dashboard for monitoring and managing multiple Claude Code sessions",
  "main": "dist/index.js",
  "bin": {
    "command-centre": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "setup": "node dist/setup.js",
    "setup:wizard": "node setup-wizard.js",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "update": "node scripts/auto-update.js",
    "update:start": "node scripts/auto-update.js --start",
    "watchdog": "node scripts/watchdog.js",
    "svc:install": "node scripts/install-service.js",
    "svc:uninstall": "node -e \"require('fs').unlinkSync(require('path').join(process.env.APPDATA,'Microsoft','Windows','Start Menu','Programs','Startup','CommandCentre.bat'));console.log('Removed startup script')\"",
    "svc:status": "node -e \"const p=require('path').join(process.env.APPDATA,'Microsoft','Windows','Start Menu','Programs','Startup','CommandCentre.bat');console.log(require('fs').existsSync(p)?'Installed: '+p:'Not installed')\""
  },
  "keywords": [
    "claude",
    "code",
    "dashboard",
    "session",
    "monitor"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "open": "^10.1.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
