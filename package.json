{
  "name": "claude-command-centre",
  "version": "0.1.0",
  "description": "Web dashboard for monitoring and managing multiple Claude Code sessions",
  "main": "dist/index.js",
  "bin": {
    "command-centre": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "setup": "node dist/setup.js",
    "setup:wizard": "node setup-wizard.js",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "pm2:start": "pm2 start dist/index.js --name command-centre --output logs/out.log --error logs/error.log",
    "pm2:stop": "pm2 stop command-centre",
    "pm2:restart": "pm2 restart command-centre",
    "pm2:status": "pm2 status command-centre",
    "pm2:logs": "pm2 logs command-centre",
    "pm2:startup": "pm2 startup && pm2 save"
  },
  "keywords": [
    "claude",
    "code",
    "dashboard",
    "session",
    "monitor"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "node-notifier": "^10.0.1",
    "open": "^10.1.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
